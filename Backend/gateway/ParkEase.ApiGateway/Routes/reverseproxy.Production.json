      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },

      "parkinglot-route": {
        "ClusterId": "parkinglot-cluster",
        "Match": {
